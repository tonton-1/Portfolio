                            </div>
                            <div class="group flex flex-col items-center gap-2.5 cursor-default">
                                <i class="devicon-ubuntu-plain colored text-5xl transition-transform duration-300 group-hover:-translate-y-1"></i>
                                <span class="text-sm font-medium text-slate-500 group-hover:text-slate-900 transition-colors duration-300">Ubuntu</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Certifications -->
        <section id="certifications" class="max-w-6xl mx-auto px-6 py-20 md:py-32">
            <h2 class="text-3xl font-bold text-slate-900 mb-16 text-center reveal">Certifications & Achievements</h2>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {certificates.map((cert) => (
                <a href={cert.url} target="_blank" class="group block bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:border-emerald-500/40 transition-all duration-300 hover:-translate-y-1 reveal reveal-delay-1 relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 w-24 h-24 bg-emerald-50 rounded-full group-hover:scale-[2] transition-transform duration-500 ease-out z-0"></div>
                    
                    <div class="relative z-10 hidden md:block">
                        <svg class="w-10 h-10 text-emerald-500 mb-5 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"></path>
                        </svg>
                    </div>

                    <div class="relative z-10">
                        <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-2">{cert.category}</p>
                        <h3 class="text-xl font-bold text-slate-900 group-hover:text-emerald-700 transition-colors leading-snug mb-5">{cert.title}</h3>
                        
                        <div class="flex items-center text-sm font-semibold text-emerald-600 group-hover:text-emerald-700 mt-auto">
                            <span>Verify credential</span>
                            <svg class="w-4 h-4 ml-1 opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </div>
                    </div>
                </a>
                ))}
            </div>
            
            <p class="text-center mt-12 text-sm font-semibold text-slate-500 flex items-center justify-center gap-2 reveal">
                <i class="devicon-hackerrank-plain text-xl text-emerald-500"></i>
                Certified by HackerRank
            </p>
        </section>
    </main>

    <!-- Toast notification -->
    <div id="copy-toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-sm font-medium px-5 py-2.5 rounded-full shadow-lg opacity-0 pointer-events-none transition-all duration-300 z-50">
        ✓ Copied to clipboard!
    </div>

    <!-- Footer -->
    <footer id="contact" class="border-t border-gray-100 py-16 mt-10">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <p class="text-sm font-medium text-slate-400 uppercase tracking-widest mb-4">Get in touch</p>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8">Let's connect.</h2>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">

                <!-- Email copy button -->
                <button id="copy-email-btn" class="group flex items-center gap-3 px-6 py-3 rounded-full border-2 border-slate-200 hover:border-slate-900 transition-all duration-300">
                    <svg class="w-4 h-4 text-slate-400 group-hover:text-slate-700 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                    <span class="text-sm font-medium text-slate-600 group-hover:text-slate-900 transition-colors">wattanachaipum@gmail.com</span>
                    <svg class="w-4 h-4 text-slate-300 group-hover:text-slate-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75" />
                    </svg>
                </button>

                <!-- GitHub link -->
                <a href="https://github.com/tonton-1" target="_blank" class="group flex items-center gap-3 px-6 py-3 rounded-full border-2 border-slate-200 hover:border-slate-900 transition-all duration-300">
                    <svg class="w-4 h-4 text-slate-400 group-hover:text-slate-700 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-sm font-medium text-slate-600 group-hover:text-slate-900 transition-colors">github.com/tonton-1</span>
                </a>

            </div>

            <p class="mt-12 text-xs text-slate-300">© {new Date().getFullYear()} Wattanachai Pummala</p>
        </div>
    </footer>

    <!-- Back to Top Button -->
    <button id="back-to-top" class="fixed bottom-8 right-8 w-11 h-11 bg-slate-900 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 hover:bg-slate-700 hover:-translate-y-1 z-40">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
        </svg>
    </button>

    <script>
        // Scroll reveal
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.12 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        // Copy email to clipboard
        const copyBtn = document.getElementById('copy-email-btn');
        const toast = document.getElementById('copy-toast');

        copyBtn?.addEventListener('click', () => {
            navigator.clipboard.writeText('wattanachaipum@gmail.com').then(() => {
                if (!toast) return;
                toast.style.opacity = '1';
                setTimeout(() => { toast.style.opacity = '0'; }, 2000);
            });
        });
        // Back to top
        const backToTop = document.getElementById('back-to-top') as HTMLElement | null;
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                if (backToTop) { backToTop.style.opacity = '1'; backToTop.style.pointerEvents = 'auto'; }
            } else {
                if (backToTop) { backToTop.style.opacity = '0'; backToTop.style.pointerEvents = 'none'; }
            }
        });
        backToTop?.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
</body>
